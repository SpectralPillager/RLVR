ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda-12.4/bin/nvcc

cflags = -DTORCH_EXTENSION_NAME=rwkv7_fp16_state_v2 -DTORCH_API_INCLUDE_EXTENSION_H -DPYBIND11_COMPILER_TYPE=\"_gcc\" -DPYBIND11_STDLIB=\"_libstdcpp\" -DPYBIND11_BUILD_ABI=\"_cxxabi1011\" -isystem /data/compute_zjx/miniconda3/envs/rwkv/lib/python3.12/site-packages/torch/include -isystem /data/compute_zjx/miniconda3/envs/rwkv/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -isystem /data/compute_zjx/miniconda3/envs/rwkv/lib/python3.12/site-packages/torch/include/TH -isystem /data/compute_zjx/miniconda3/envs/rwkv/lib/python3.12/site-packages/torch/include/THC -isystem /usr/local/cuda-12.4/include -isystem /data/compute_zjx/miniconda3/envs/rwkv/include/python3.12 -D_GLIBCXX_USE_CXX11_ABI=0 -fPIC -std=c++17
post_cflags = 
cuda_cflags = -DTORCH_EXTENSION_NAME=rwkv7_fp16_state_v2 -DTORCH_API_INCLUDE_EXTENSION_H -DPYBIND11_COMPILER_TYPE=\"_gcc\" -DPYBIND11_STDLIB=\"_libstdcpp\" -DPYBIND11_BUILD_ABI=\"_cxxabi1011\" -isystem /data/compute_zjx/miniconda3/envs/rwkv/lib/python3.12/site-packages/torch/include -isystem /data/compute_zjx/miniconda3/envs/rwkv/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -isystem /data/compute_zjx/miniconda3/envs/rwkv/lib/python3.12/site-packages/torch/include/TH -isystem /data/compute_zjx/miniconda3/envs/rwkv/lib/python3.12/site-packages/torch/include/THC -isystem /usr/local/cuda-12.4/include -isystem /data/compute_zjx/miniconda3/envs/rwkv/include/python3.12 -D_GLIBCXX_USE_CXX11_ABI=0 -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr -gencode=arch=compute_89,code=sm_89 --compiler-options '-fPIC' -res-usage --use_fast_math -O3 --extra-device-vectorization -D_N_=64 -Xptxas -O3 -std=c++17
cuda_post_cflags = 
cuda_dlink_post_cflags = 
ldflags = -shared -L/data/compute_zjx/miniconda3/envs/rwkv/lib/python3.12/site-packages/torch/lib -lc10 -lc10_cuda -ltorch_cpu -ltorch_cuda -ltorch -ltorch_python -L/usr/local/cuda-12.4/lib64 -lcudart

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags



rule link
  command = $cxx $in $ldflags -o $out

build rwkv7_state_fwd_fp16_state_fp16_v2.o: compile /data_temp/mnt/raid5/zjx/rwkv/full-training/reference/cuda/rwkv7_state_fwd_fp16_state_fp16_v2.cpp
build rwkv7_state_fwd_fp16_state_fp16_v2.cuda.o: cuda_compile /data_temp/mnt/raid5/zjx/rwkv/full-training/reference/cuda/rwkv7_state_fwd_fp16_state_fp16_v2.cu



build rwkv7_fp16_state_v2.so: link rwkv7_state_fwd_fp16_state_fp16_v2.o rwkv7_state_fwd_fp16_state_fp16_v2.cuda.o

default rwkv7_fp16_state_v2.so
